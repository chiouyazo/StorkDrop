<Window
  x:Class="StorkDrop.App.Views.PluginConfigDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:contracts="clr-namespace:StorkDrop.Contracts;assembly=StorkDrop.Contracts"
  xmlns:vm="clr-namespace:StorkDrop.App.ViewModels"
  Title="Plugin-Konfiguration"
  Width="560"
  MinHeight="400"
  SizeToContent="Height"
  WindowStartupLocation="CenterOwner"
  ResizeMode="CanResizeWithGrip"
  Background="{DynamicResource SurfaceBrush}"
>
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Window.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
      Grid.Row="0"
      Text="Plugin-Konfiguration"
      Style="{DynamicResource HeadingMedium}"
      Margin="0,0,0,16"
    />

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
      <ItemsControl ItemsSource="{Binding Fields}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:PluginConfigFieldViewModel}">
            <StackPanel Margin="0,0,0,12">
              <!-- Label -->
              <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="{Binding Label}" Style="{DynamicResource BodyText}" />
                <TextBlock
                  Text=" *"
                  Foreground="{DynamicResource ErrorBrush}"
                  Visibility="{Binding Required, Converter={StaticResource BoolToVis}}"
                />
                <Border
                  Visibility="{Binding Description, Converter={StaticResource BoolToVis}}"
                  ToolTip="{Binding Description}"
                  Margin="6,0,0,0"
                  Width="16"
                  Height="16"
                  CornerRadius="8"
                  Background="#CCCCCC"
                  Cursor="Help"
                  VerticalAlignment="Center"
                >
                  <TextBlock
                    Text="?"
                    FontSize="10"
                    FontWeight="Bold"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                  />
                </Border>
              </StackPanel>

              <!-- Text -->
              <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                  <Style TargetType="TextBox" BasedOn="{StaticResource StyledTextBox}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding FieldType}"
                        Value="{x:Static contracts:PluginFieldType.Text}"
                      >
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBox.Style>
              </TextBox>

              <!-- Number -->
              <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                  <Style TargetType="TextBox" BasedOn="{StaticResource StyledTextBox}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding FieldType}"
                        Value="{x:Static contracts:PluginFieldType.Number}"
                      >
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBox.Style>
              </TextBox>

              <ComboBox
                SelectedValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                SelectedValuePath="Value"
                DisplayMemberPath="Label"
                ItemsSource="{Binding Options}"
              >
                <ComboBox.Style>
                  <Style TargetType="ComboBox">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding FieldType}"
                        Value="{x:Static contracts:PluginFieldType.Dropdown}"
                      >
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding FieldType}">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding FieldType}">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </ComboBox.Style>
              </ComboBox>

              <!-- Checkbox -->
              <CheckBox
                Content="{Binding Label}"
                Tag="{Binding}"
                Checked="CheckBox_Changed"
                Unchecked="CheckBox_Changed"
                Loaded="CheckBox_Loaded"
              >
                <CheckBox.Style>
                  <Style TargetType="CheckBox">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding FieldType}"
                        Value="{x:Static contracts:PluginFieldType.Checkbox}"
                      >
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </CheckBox.Style>
              </CheckBox>

              <!-- Password -->
              <PasswordBox Tag="{Binding}" PasswordChanged="PasswordBox_PasswordChanged">
                <PasswordBox.Style>
                  <Style TargetType="PasswordBox">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding FieldType}"
                        Value="{x:Static contracts:PluginFieldType.Password}"
                      >
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </PasswordBox.Style>
              </PasswordBox>

              <!-- FilePath -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.Style>
                  <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding FieldType}"
                        Value="{x:Static contracts:PluginFieldType.FilePath}"
                      >
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Grid.Style>
                <TextBox
                  Grid.Column="0"
                  Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                  Style="{DynamicResource StyledTextBox}"
                  Margin="0,0,8,0"
                />
                <Button
                  Grid.Column="1"
                  Content="..."
                  Style="{DynamicResource OutlinedButton}"
                  Padding="8,6"
                  Tag="{Binding}"
                  Click="BrowseFile_Click"
                />
              </Grid>

              <!-- FolderPath -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.Style>
                  <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding FieldType}"
                        Value="{x:Static contracts:PluginFieldType.FolderPath}"
                      >
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Grid.Style>
                <TextBox
                  Grid.Column="0"
                  Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                  Style="{DynamicResource StyledTextBox}"
                  Margin="0,0,8,0"
                />
                <Button
                  Grid.Column="1"
                  Content="..."
                  Style="{DynamicResource OutlinedButton}"
                  Padding="8,6"
                  Tag="{Binding}"
                  Click="BrowseFolder_Click"
                />
              </Grid>

              <!-- MultiSelect -->
              <ListBox
                ItemsSource="{Binding Options}"
                SelectionMode="Multiple"
                MaxHeight="150"
                Tag="{Binding}"
                SelectionChanged="MultiSelect_SelectionChanged"
              >
                <ListBox.Style>
                  <Style TargetType="ListBox">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding FieldType}"
                        Value="{x:Static contracts:PluginFieldType.MultiSelect}"
                      >
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </ListBox.Style>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding Label}" Tag="{Binding Value}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <!-- Error message -->
              <TextBlock
                Text="{Binding ErrorMessage}"
                Foreground="{DynamicResource ErrorBrush}"
                FontSize="11"
                Margin="0,2,0,0"
                TextWrapping="Wrap"
              >
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding HasError}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Global error message -->
    <TextBlock
      Grid.Row="2"
      Text="{Binding GlobalErrorMessage}"
      Foreground="{DynamicResource ErrorBrush}"
      FontSize="12"
      TextWrapping="Wrap"
      Margin="0,0,0,8"
    >
      <TextBlock.Style>
        <Style TargetType="TextBlock">
          <Setter Property="Visibility" Value="Visible" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding GlobalErrorMessage}" Value="">
              <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </TextBlock.Style>
    </TextBlock>

    <!-- Buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button
        Content="Abbrechen"
        Style="{DynamicResource OutlinedButton}"
        Padding="16,8"
        Margin="0,0,8,0"
        Click="Cancel_Click"
      />
      <Button
        Content="Weiter"
        Style="{DynamicResource FilledAccentButton}"
        Padding="16,8"
        Click="Continue_Click"
      />
    </StackPanel>
  </Grid>
</Window>
