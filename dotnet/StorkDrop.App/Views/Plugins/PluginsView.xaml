<UserControl
  x:Class="StorkDrop.App.Views.Plugins.PluginsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock
      Text="{DynamicResource Plugins_Title}"
      Style="{DynamicResource HeadingLarge}"
      Margin="0,0,0,16"
    />

    <ItemsControl Grid.Row="1" ItemsSource="{Binding LoadedPlugins}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Style="{DynamicResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock
                Text="{Binding DisplayName}"
                Style="{DynamicResource HeadingSmall}"
                Margin="0,0,0,4"
              />
              <TextBlock Style="{DynamicResource BodyText}">
                <Run Text="Plugin ID: " FontWeight="SemiBold" />
                <Run Text="{Binding PluginId, Mode=OneWay}" />
              </TextBlock>
              <TextBlock Style="{DynamicResource BodyText}">
                <Run Text="Associated Feeds: " FontWeight="SemiBold" />
                <Run Text="{Binding AssociatedFeeds, Mode=OneWay}" />
              </TextBlock>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Empty state -->
    <TextBlock
      Grid.Row="1"
      Text="No plugins loaded. Drop plugin DLLs into the plugins/ directory next to the application."
      Style="{DynamicResource CaptionText}"
      Foreground="{DynamicResource OnSurfaceVariantBrush}"
      VerticalAlignment="Center"
      HorizontalAlignment="Center"
      Visibility="{Binding LoadedPlugins.Count, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
    />
  </Grid>
</UserControl>
