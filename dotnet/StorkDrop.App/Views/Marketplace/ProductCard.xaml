<UserControl
  x:Class="StorkDrop.App.Views.Marketplace.ProductCard"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:converters="clr-namespace:StorkDrop.App.Converters"
  Width="260"
>
  <UserControl.Resources>
    <converters:BadgeColorConverter x:Key="BadgeColorConverter" />
  </UserControl.Resources>
  <Border Style="{DynamicResource CardBorder}" Cursor="Hand" MouseLeftButtonDown="OnCardClick">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Product image or icon fallback -->
        <Grid Width="40" Height="40" VerticalAlignment="Center">
          <!-- Loading placeholder -->
          <Border
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="4"
            Visibility="{Binding IsImageLoading, Converter={StaticResource BoolToVisibilityConverter}}"
          >
            <TextBlock
              Text="&#xE895;"
              FontFamily="Segoe MDL2 Assets"
              FontSize="20"
              Foreground="#CCCCCC"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
            />
          </Border>

          <!-- Loaded image -->
          <Image Source="{Binding ProductImage}" Width="40" Height="40" Stretch="Uniform">
            <Image.Style>
              <Style TargetType="Image">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding ProductImage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Image.Style>
          </Image>

          <!-- Fallback icon when no image -->
          <TextBlock
            Text="{Binding InstallType, Converter={StaticResource InstallTypeToIconConverter}}"
            FontFamily="Segoe MDL2 Assets"
            FontSize="32"
            Foreground="{DynamicResource AccentRedBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
          >
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding ProductImage}" Value="{x:Null}" />
                      <Condition Binding="{Binding IsImageLoading}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <Border
          Grid.Column="2"
          Background="{DynamicResource SurfaceBrush}"
          CornerRadius="4"
          Padding="8,2"
          VerticalAlignment="Top"
        >
          <TextBlock
            Text="{Binding InstallType}"
            FontSize="11"
            FontWeight="SemiBold"
            Foreground="#666666"
          />
        </Border>
      </Grid>

      <Border
        Grid.Row="1"
        CornerRadius="3"
        Padding="6,2"
        Margin="0,0,0,2"
        HorizontalAlignment="Left"
        Background="{Binding BadgeColor, Converter={StaticResource BadgeColorConverter}}"
        Visibility="{Binding HasBadge, Converter={StaticResource BoolToVisibilityConverter}}"
      >
        <TextBlock
          Text="{Binding BadgeText}"
          FontSize="10"
          FontWeight="Bold"
          Foreground="{Binding BadgeColor, Converter={StaticResource BadgeColorConverter}, ConverterParameter=foreground}"
        />
      </Border>

      <Viewbox
        Grid.Row="2"
        HorizontalAlignment="Left"
        StretchDirection="DownOnly"
        Stretch="Uniform"
        Margin="0,0,0,4"
      >
        <TextBlock Text="{Binding Title}" Style="{DynamicResource HeadingSmall}" />
      </Viewbox>

      <TextBlock
        Grid.Row="3"
        Text="{Binding FeedDisplay}"
        FontSize="11"
        Foreground="#AAAAAA"
        Visibility="{Binding HasFeedDisplay, Converter={StaticResource BoolToVisibilityConverter}}"
        Margin="0,0,0,2"
      />

      <Viewbox
        Grid.Row="4"
        HorizontalAlignment="Left"
        StretchDirection="DownOnly"
        Stretch="Uniform"
        Margin="0,0,0,8"
      >
        <TextBlock Text="{Binding VersionDisplay}" FontSize="12" Foreground="#999999" />
      </Viewbox>

      <TextBlock
        Grid.Row="5"
        Text="{Binding Description}"
        FontSize="12"
        TextWrapping="Wrap"
        TextTrimming="CharacterEllipsis"
        MaxHeight="48"
        Foreground="#666666"
        Margin="0,0,0,12"
      />

      <Grid Grid.Row="6">
        <!-- State 1: Not installed, not installing -> Install button -->
        <Button
          Content="{DynamicResource Install_Button}"
          HorizontalAlignment="Stretch"
          Command="{Binding DataContext.InstallProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
          CommandParameter="{Binding}"
        >
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource FilledAccentButton}">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>

        <!-- State 2: Installing -> Progress bar -->
        <StackPanel Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibilityConverter}}">
          <TextBlock
            Text="{Binding InstallStatusMessage}"
            FontSize="11"
            Foreground="#999999"
            HorizontalAlignment="Center"
            Margin="0,4,0,6"
          />
          <ProgressBar Value="{Binding InstallPercentage}" Maximum="100" Height="4">
            <ProgressBar.Style>
              <Style TargetType="ProgressBar" BasedOn="{StaticResource StyledProgressBar}">
                <Setter Property="IsIndeterminate" Value="False" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding InstallPercentage}" Value="0">
                    <Setter Property="IsIndeterminate" Value="True" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ProgressBar.Style>
          </ProgressBar>
        </StackPanel>

        <!-- State 3: Installed, has update -> Update button -->
        <Button
          Content="{DynamicResource Install_Update}"
          HorizontalAlignment="Stretch"
          Command="{Binding DataContext.InstallProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
          CommandParameter="{Binding}"
        >
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource FilledAccentButton}">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding HasUpdate}" Value="True" />
                    <Condition Binding="{Binding IsInstalling}" Value="False" />
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>

        <!-- State 4: Installed, no update -> "Installed" or "Downloaded" label -->
        <TextBlock FontSize="13" Foreground="#2E7D32" HorizontalAlignment="Center" Padding="0,8">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed" />
              <Setter Property="Text" Value="{DynamicResource Install_Installed}" />
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsInstalled}" Value="True" />
                    <Condition Binding="{Binding HasUpdate}" Value="False" />
                    <Condition Binding="{Binding IsInstalling}" Value="False" />
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsExecutable}" Value="True">
                  <Setter Property="Text" Value="{DynamicResource Installed_Downloaded}" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </Grid>
  </Border>
</UserControl>
