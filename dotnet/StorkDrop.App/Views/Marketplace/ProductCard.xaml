<UserControl
    x:Class="StorkDrop.App.Views.Marketplace.ProductCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="260"
>
    <Border Style="{DynamicResource CardBorder}" Cursor="Hand" MouseLeftButtonDown="OnCardClick">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Product image or icon fallback -->
                <Grid Width="40" Height="40" VerticalAlignment="Center">
                    <!-- Loading placeholder -->
                    <Border
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="4"
                        Visibility="{Binding IsImageLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    >
                        <TextBlock
                            Text="&#xE895;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="20"
                            Foreground="#CCCCCC"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                        />
                    </Border>

                    <!-- Loaded image -->
                    <Image Source="{Binding ProductImage}" Width="40" Height="40" Stretch="Uniform">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProductImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <!-- Fallback icon when no image -->
                    <TextBlock
                        Text="{Binding InstallType, Converter={StaticResource InstallTypeToIconConverter}}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="32"
                        Foreground="{DynamicResource AccentRedBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                    >
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition
                                                Binding="{Binding ProductImage}"
                                                Value="{x:Null}"
                                            />
                                            <Condition
                                                Binding="{Binding IsImageLoading}"
                                                Value="False"
                                            />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Border
                    Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="4"
                    Padding="8,4"
                >
                    <TextBlock
                        Text="{Binding InstallType}"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="#666666"
                    />
                </Border>
            </Grid>

            <TextBlock
                Grid.Row="1"
                Text="{Binding Title}"
                Style="{DynamicResource HeadingSmall}"
                TextTrimming="CharacterEllipsis"
                Margin="0,0,0,4"
            />

            <TextBlock
                Grid.Row="2"
                Text="{Binding Version, StringFormat='v{0}'}"
                FontSize="12"
                Foreground="#999999"
                Margin="0,0,0,8"
            />

            <TextBlock
                Grid.Row="3"
                Text="{Binding Description}"
                FontSize="12"
                TextWrapping="Wrap"
                TextTrimming="CharacterEllipsis"
                MaxHeight="48"
                Foreground="#666666"
                Margin="0,0,0,12"
            />

            <Grid Grid.Row="4">
                <!-- State 1: Not installed, not installing -> Install button -->
                <Button
                    Content="{DynamicResource Install_Button}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding DataContext.InstallProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"
                >
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilledAccentButton}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- State 2: Installing -> Progress bar -->
                <StackPanel Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock
                        Text="{Binding InstallStatusMessage}"
                        FontSize="11"
                        Foreground="#999999"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,6"
                    />
                    <ProgressBar
                        Value="{Binding InstallPercentage}"
                        Maximum="100"
                        Height="4"
                        Style="{DynamicResource StyledProgressBar}"
                    />
                </StackPanel>

                <!-- State 3: Installed, has update -> Update button -->
                <Button
                    Content="Update"
                    HorizontalAlignment="Stretch"
                    Command="{Binding DataContext.InstallProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"
                >
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilledAccentButton}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasUpdate}" Value="True" />
                                        <Condition Binding="{Binding IsInstalling}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- State 4: Installed, no update -> "Installed" label -->
                <TextBlock
                    Text="{DynamicResource Install_Installed}"
                    FontSize="13"
                    Foreground="#2E7D32"
                    HorizontalAlignment="Center"
                    Padding="0,8"
                >
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsInstalled}" Value="True" />
                                        <Condition Binding="{Binding HasUpdate}" Value="False" />
                                        <Condition Binding="{Binding IsInstalling}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</UserControl>
