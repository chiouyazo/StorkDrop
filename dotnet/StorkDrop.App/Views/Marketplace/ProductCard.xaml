<UserControl
  x:Class="StorkDrop.App.Views.Marketplace.ProductCard"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Width="260"
>
  <Border Style="{DynamicResource CardBorder}" Cursor="Hand" MouseLeftButtonDown="OnCardClick">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Product image or icon fallback -->
        <Grid Width="40" Height="40" VerticalAlignment="Center">
          <!-- Loading placeholder -->
          <Border
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="4"
            Visibility="{Binding IsImageLoading, Converter={StaticResource BoolToVisibilityConverter}}"
          >
            <TextBlock
              Text="&#xE895;"
              FontFamily="Segoe MDL2 Assets"
              FontSize="20"
              Foreground="#CCCCCC"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
            />
          </Border>

          <!-- Loaded image -->
          <Image Source="{Binding ProductImage}" Width="40" Height="40" Stretch="Uniform">
            <Image.Style>
              <Style TargetType="Image">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding ProductImage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Image.Style>
          </Image>

          <!-- Fallback icon when no image -->
          <TextBlock
            Text="{Binding InstallType, Converter={StaticResource InstallTypeToIconConverter}}"
            FontFamily="Segoe MDL2 Assets"
            FontSize="32"
            Foreground="{DynamicResource AccentRedBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
          >
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding ProductImage}" Value="{x:Null}" />
                      <Condition Binding="{Binding IsImageLoading}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <Border
          Grid.Column="2"
          Background="{DynamicResource SurfaceBrush}"
          CornerRadius="4"
          Padding="8,2"
          VerticalAlignment="Top"
        >
          <TextBlock
            Text="{Binding InstallType}"
            FontSize="11"
            FontWeight="SemiBold"
            Foreground="#666666"
          />
        </Border>
      </Grid>

      <Viewbox
        Grid.Row="1"
        HorizontalAlignment="Left"
        StretchDirection="DownOnly"
        Stretch="Uniform"
        Margin="0,0,0,4"
      >
        <TextBlock Text="{Binding Title}" Style="{DynamicResource HeadingSmall}" />
      </Viewbox>

      <Viewbox
        Grid.Row="2"
        HorizontalAlignment="Left"
        StretchDirection="DownOnly"
        Stretch="Uniform"
        Margin="0,0,0,2"
        Visibility="{Binding HasFeedDisplay, Converter={StaticResource BoolToVisibilityConverter}}"
      >
        <TextBlock Text="{Binding FeedDisplay}" FontSize="12" Foreground="#999999" />
      </Viewbox>

      <Viewbox
        Grid.Row="3"
        HorizontalAlignment="Left"
        StretchDirection="DownOnly"
        Stretch="Uniform"
        Margin="0,0,0,8"
      >
        <TextBlock Text="{Binding VersionDisplay}" FontSize="12" Foreground="#999999" />
      </Viewbox>

      <TextBlock
        Grid.Row="4"
        Text="{Binding Description}"
        FontSize="12"
        TextWrapping="Wrap"
        TextTrimming="CharacterEllipsis"
        MaxHeight="48"
        Foreground="#666666"
        Margin="0,0,0,12"
      />

      <Grid Grid.Row="5">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Install button - navigates to product detail -->
        <Button
          Style="{DynamicResource FilledAccentButton}"
          HorizontalAlignment="Stretch"
          Command="{Binding DataContext.NavigateToDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
          CommandParameter="{Binding}"
        >
          <Button.Content>
            <TextBlock>
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Text" Value="{DynamicResource Install_Button}" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding ShowInstalledLabel}" Value="True">
                      <Setter Property="Text" Value="{DynamicResource Installed_Status}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Button.Content>
        </Button>

        <!-- Manage gear icon -->
        <Button
          Grid.Column="1"
          Content="&#xE713;"
          FontFamily="Segoe MDL2 Assets"
          FontSize="14"
          Padding="8,6"
          Margin="6,0,0,0"
          ToolTip="{DynamicResource Manage_Button}"
          Command="{Binding DataContext.ManageProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
          CommandParameter="{Binding}"
        >
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource OutlinedButton}">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding ShowManageButton}" Value="True">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
      </Grid>
    </Grid>
  </Border>
</UserControl>
