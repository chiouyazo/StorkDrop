<UserControl
  x:Class="StorkDrop.App.Views.PluginTab.PluginTabView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="700">
      <TextBlock Text="{Binding Title}" Style="{DynamicResource HeadingLarge}" Margin="0,0,0,24" />

      <!-- === STEPS: Database Connections === -->
      <Border
        Style="{DynamicResource CardBorder}"
        Margin="0,0,0,16"
        Visibility="{Binding IsStepsPlugin, Converter={StaticResource BoolToVisibilityConverter}}"
      >
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock
              Text="Database Connections"
              Style="{DynamicResource HeadingSmall}"
              VerticalAlignment="Center"
            />
            <Button
              Content="+ Add Database"
              Style="{DynamicResource OutlinedButton}"
              Command="{Binding AddDatabaseCommand}"
              Margin="12,0,0,0"
              Padding="12,4"
            />
          </StackPanel>

          <ItemsControl ItemsSource="{Binding Databases}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="0,0,0,1"
                  Margin="0,0,0,12"
                  Padding="0,0,0,12"
                >
                  <StackPanel>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock
                          Text="Display Name"
                          Style="{DynamicResource CaptionText}"
                          Margin="0,0,0,4"
                        />
                        <TextBox
                          Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource StyledTextBox}"
                        />
                      </StackPanel>
                      <Button
                        Grid.Column="1"
                        Content="Remove"
                        Style="{DynamicResource OutlinedButton}"
                        Command="{Binding DataContext.RemoveDatabaseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Padding="8,2"
                        FontSize="11"
                        VerticalAlignment="Top"
                        Margin="8,20,0,0"
                      />
                    </Grid>

                    <TextBlock
                      Text="Server"
                      Style="{DynamicResource CaptionText}"
                      Margin="0,0,0,4"
                    />
                    <TextBox
                      Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                      Style="{DynamicResource StyledTextBox}"
                      Margin="0,0,0,8"
                    />

                    <TextBlock
                      Text="Database Name"
                      Style="{DynamicResource CaptionText}"
                      Margin="0,0,0,4"
                    />
                    <TextBox
                      Text="{Binding DatabaseName, UpdateSourceTrigger=PropertyChanged}"
                      Style="{DynamicResource StyledTextBox}"
                      Margin="0,0,0,8"
                    />

                    <CheckBox
                      Content="Use Windows Authentication"
                      IsChecked="{Binding UseWindowsAuth}"
                      Margin="0,0,0,8"
                    />

                    <!-- SQL credentials (hidden when Windows auth) -->
                    <StackPanel>
                      <StackPanel.Style>
                        <Style TargetType="StackPanel">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding UseWindowsAuth}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </StackPanel.Style>
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                          <TextBlock
                            Text="Username"
                            Style="{DynamicResource CaptionText}"
                            Margin="0,0,0,4"
                          />
                          <TextBox
                            Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                            Style="{DynamicResource StyledTextBox}"
                          />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                          <TextBlock
                            Text="Password"
                            Style="{DynamicResource CaptionText}"
                            Margin="0,0,0,4"
                          />
                          <PasswordBox
                            Padding="8,8"
                            FontSize="13"
                            MinHeight="36"
                            Tag="{Binding}"
                            PasswordChanged="OnDbPasswordChanged"
                          />
                        </StackPanel>
                      </Grid>
                    </StackPanel>

                    <CheckBox
                      Content="Trust Server Certificate"
                      IsChecked="{Binding TrustCertificate}"
                      Margin="0,0,0,8"
                    />

                    <StackPanel Orientation="Horizontal">
                      <Button
                        Content="{DynamicResource Button_TestConnection}"
                        Style="{DynamicResource OutlinedButton}"
                        Command="{Binding DataContext.TestDatabaseCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Padding="12,6"
                        Margin="0,0,12,0"
                      />
                      <TextBlock
                        Text="{Binding ConnectionTestMessage}"
                        VerticalAlignment="Center"
                        FontSize="13"
                      >
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding ConnectionTestSuccess}" Value="True">
                                <Setter
                                  Property="Foreground"
                                  Value="{DynamicResource SuccessBrush}"
                                />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding ConnectionTestSuccess}" Value="False">
                                <Setter
                                  Property="Foreground"
                                  Value="{DynamicResource ErrorBrush}"
                                />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Empty state -->
          <TextBlock
            Text="No databases configured yet. Click '+ Add Database' to add one."
            Foreground="{DynamicResource OnSurfaceVariantBrush}"
            FontSize="13"
            Margin="0,4,0,0"
          >
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Databases.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Border>

      <!-- === STEPS: Application Paths === -->
      <Border
        Style="{DynamicResource CardBorder}"
        Margin="0,0,0,16"
        Visibility="{Binding IsStepsPlugin, Converter={StaticResource BoolToVisibilityConverter}}"
      >
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock
              Text="STEPS Application Paths"
              Style="{DynamicResource HeadingSmall}"
              VerticalAlignment="Center"
            />
            <Button
              Content="+ Add Path"
              Style="{DynamicResource OutlinedButton}"
              Command="{Binding AddStepsPathCommand}"
              Margin="12,0,0,0"
              Padding="12,4"
            />
          </StackPanel>

          <ItemsControl ItemsSource="{Binding StepsPaths}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="0,0,0,1"
                  Margin="0,0,0,12"
                  Padding="0,0,0,12"
                >
                  <StackPanel>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock
                          Text="Display Name"
                          Style="{DynamicResource CaptionText}"
                          Margin="0,0,0,4"
                        />
                        <TextBox
                          Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource StyledTextBox}"
                        />
                      </StackPanel>
                      <Button
                        Grid.Column="1"
                        Content="Remove"
                        Style="{DynamicResource OutlinedButton}"
                        Command="{Binding DataContext.RemoveStepsPathCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Padding="8,2"
                        FontSize="11"
                        VerticalAlignment="Top"
                        Margin="8,20,0,0"
                      />
                    </Grid>

                    <TextBlock
                      Text="Application Directory"
                      Style="{DynamicResource CaptionText}"
                      Margin="0,0,0,4"
                    />
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBox
                        Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                        Style="{DynamicResource StyledTextBox}"
                        Margin="0,0,8,0"
                      />
                      <Button
                        Grid.Column="1"
                        Content="..."
                        Style="{DynamicResource OutlinedButton}"
                        Padding="8,6"
                        Command="{Binding DataContext.BrowseStepsPathCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                      />
                    </Grid>

                    <CheckBox
                      Content="Remote server (deploy via RDP)"
                      IsChecked="{Binding IsRemote}"
                      Margin="0,0,0,8"
                    />

                    <!-- RDP settings (shown when IsRemote) -->
                    <StackPanel>
                      <StackPanel.Style>
                        <Style TargetType="StackPanel">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRemote}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </StackPanel.Style>
                      <Border Background="#F0F7FF" CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                          <TextBlock
                            Text="RDP Host"
                            Style="{DynamicResource CaptionText}"
                            Margin="0,0,0,4"
                          />
                          <TextBox
                            Text="{Binding RdpHost, UpdateSourceTrigger=PropertyChanged}"
                            Style="{DynamicResource StyledTextBox}"
                            Margin="0,0,0,8"
                          />

                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0">
                              <TextBlock
                                Text="RDP Username"
                                Style="{DynamicResource CaptionText}"
                                Margin="0,0,0,4"
                              />
                              <TextBox
                                Text="{Binding RdpUsername, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource StyledTextBox}"
                              />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                              <TextBlock
                                Text="RDP Password"
                                Style="{DynamicResource CaptionText}"
                                Margin="0,0,0,4"
                              />
                              <PasswordBox
                                Padding="8,8"
                                FontSize="13"
                                MinHeight="36"
                                Tag="{Binding}"
                                PasswordChanged="OnRdpPasswordChanged"
                              />
                            </StackPanel>
                          </Grid>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Empty state -->
          <TextBlock
            Text="No STEPS paths configured yet. Click '+ Add Path' to add one."
            Foreground="{DynamicResource OnSurfaceVariantBrush}"
            FontSize="13"
            Margin="0,4,0,0"
          >
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding StepsPaths.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Border>

      <!-- Status -->
      <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,0,0,8">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding StatusMessage}" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>

      <!-- Save -->
      <Button
        Content="{DynamicResource Button_Save}"
        Style="{DynamicResource FilledAccentButton}"
        Command="{Binding SaveCommand}"
        HorizontalAlignment="Left"
        MinWidth="160"
        Margin="0,0,0,24"
        Visibility="{Binding IsStepsPlugin, Converter={StaticResource BoolToVisibilityConverter}}"
      />
    </StackPanel>
  </ScrollViewer>
</UserControl>
