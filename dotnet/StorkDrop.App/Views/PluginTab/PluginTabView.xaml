<UserControl
  x:Class="StorkDrop.App.Views.PluginTab.PluginTabView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="clr-namespace:StorkDrop.App.ViewModels"
>
  <UserControl.Resources>
    <!-- Template for rendering a single field (reused in sections and group instances) -->
    <DataTemplate x:Key="FieldTemplate" DataType="{x:Type vm:PluginConfigFieldViewModel}">
      <StackPanel Margin="0,0,0,8">
        <TextBlock
          Text="{Binding Label}"
          Style="{DynamicResource CaptionText}"
          FontWeight="SemiBold"
          Margin="0,0,0,4"
        />

        <!-- Text / Number -->
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}">
          <TextBox.Style>
            <Style TargetType="TextBox" BasedOn="{StaticResource StyledTextBox}">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding FieldTypeName}" Value="Text">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FieldTypeName}" Value="Number">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBox.Style>
        </TextBox>

        <!-- Password -->
        <Border>
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed" />
              <Setter Property="BorderBrush" Value="#E0E0E0" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="CornerRadius" Value="4" />
              <Setter Property="Background" Value="White" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding FieldTypeName}" Value="Password">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <PasswordBox
            Padding="8,6"
            FontSize="13"
            MinHeight="36"
            VerticalContentAlignment="Center"
            BorderThickness="0"
            Background="Transparent"
            Tag="{Binding}"
            PasswordChanged="OnPasswordChanged"
          />
        </Border>

        <!-- Checkbox -->
        <CheckBox
          Content="{Binding Label}"
          Tag="{Binding}"
          Checked="OnCheckBoxChanged"
          Unchecked="OnCheckBoxChanged"
          Loaded="OnCheckBoxLoaded"
        >
          <CheckBox.Style>
            <Style TargetType="CheckBox">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding FieldTypeName}" Value="Checkbox">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </CheckBox.Style>
        </CheckBox>

        <!-- FolderPath -->
        <Grid>
          <Grid.Style>
            <Style TargetType="Grid">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding FieldTypeName}" Value="FolderPath">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Grid.Style>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox
            Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
            Style="{DynamicResource StyledTextBox}"
            Margin="0,0,8,0"
          />
          <Button
            Grid.Column="1"
            Content="..."
            Style="{DynamicResource OutlinedButton}"
            Padding="8,6"
            Command="{Binding DataContext.BrowsePathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            CommandParameter="{Binding}"
          />
        </Grid>

        <!-- Description -->
        <TextBlock
          Text="{Binding Description}"
          FontSize="11"
          Foreground="#999999"
          TextWrapping="Wrap"
          Margin="0,2,0,0"
        >
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Style.Triggers>
                <DataTrigger Binding="{Binding Description}" Value="">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="700">
      <TextBlock Text="{Binding Title}" Style="{DynamicResource HeadingLarge}" Margin="0,0,0,24" />

      <ItemsControl ItemsSource="{Binding Sections}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <!-- Regular fields -->
              <Border
                Style="{DynamicResource CardBorder}"
                Margin="0,0,0,16"
                Visibility="{Binding Fields.Count, Converter={StaticResource BoolToVisibilityConverter}}"
              >
                <StackPanel>
                  <TextBlock
                    Text="{Binding Title}"
                    Style="{DynamicResource HeadingSmall}"
                    Margin="0,0,0,12"
                  />
                  <ItemsControl
                    ItemsSource="{Binding Fields}"
                    ItemTemplate="{StaticResource FieldTemplate}"
                  />
                </StackPanel>
              </Border>

              <!-- Group fields (repeatable) -->
              <ItemsControl ItemsSource="{Binding GroupFields}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{DynamicResource CardBorder}" Margin="0,0,0,16">
                      <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                          <TextBlock
                            Text="{Binding Label}"
                            Style="{DynamicResource HeadingSmall}"
                            VerticalAlignment="Center"
                          />
                          <Button
                            Content="+ Add"
                            Style="{DynamicResource OutlinedButton}"
                            Margin="12,0,0,0"
                            Padding="12,4"
                            Command="{Binding DataContext.AddGroupInstanceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                          />
                        </StackPanel>

                        <!-- Description -->
                        <TextBlock
                          Text="{Binding Description}"
                          FontSize="12"
                          Foreground="#999999"
                          TextWrapping="Wrap"
                          Margin="0,0,0,8"
                        >
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Description}" Value="">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>

                        <!-- Group instances -->
                        <ItemsControl ItemsSource="{Binding Instances}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Margin="0,0,0,12"
                                Padding="0,0,0,12"
                              >
                                <StackPanel>
                                  <Button
                                    Content="Remove"
                                    Style="{DynamicResource OutlinedButton}"
                                    HorizontalAlignment="Right"
                                    Padding="8,2"
                                    FontSize="11"
                                    Margin="0,0,0,8"
                                    Click="OnRemoveGroupInstance"
                                  />
                                  <ItemsControl
                                    ItemsSource="{Binding Fields}"
                                    ItemTemplate="{StaticResource FieldTemplate}"
                                  />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock
                          FontSize="13"
                          Foreground="{DynamicResource OnSurfaceVariantBrush}"
                          Margin="0,4,0,0"
                        >
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Setter
                                Property="Text"
                                Value="No items configured yet. Click '+ Add' to add one."
                              />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Instances.Count}" Value="0">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Status -->
      <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,0,0,8">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding StatusMessage}" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>

      <!-- Save -->
      <Button
        Content="{DynamicResource Button_Save}"
        Style="{DynamicResource FilledAccentButton}"
        Command="{Binding SaveCommand}"
        HorizontalAlignment="Left"
        MinWidth="160"
        Margin="0,0,0,24"
      />
    </StackPanel>
  </ScrollViewer>
</UserControl>
