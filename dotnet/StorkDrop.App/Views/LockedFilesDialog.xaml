<Window
  x:Class="StorkDrop.App.Views.LockedFilesDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="{DynamicResource LockedFiles_Title}"
  Width="680"
  MaxHeight="560"
  SizeToContent="Height"
  WindowStartupLocation="CenterOwner"
  ResizeMode="NoResize"
  Background="{DynamicResource BackgroundBrush}"
>
  <StackPanel Margin="24">
    <TextBlock
      Text="{DynamicResource LockedFiles_Title}"
      FontSize="18"
      FontWeight="SemiBold"
      Margin="0,0,0,12"
    />
    <TextBlock
      Text="{DynamicResource LockedFiles_Message}"
      TextWrapping="Wrap"
      FontSize="13"
      Margin="0,0,0,16"
    />

    <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
      <ItemsControl x:Name="ProcessList">
        <ItemsControl.GroupStyle>
          <GroupStyle>
            <GroupStyle.HeaderTemplate>
              <DataTemplate>
                <TextBlock
                  Text="{Binding Name}"
                  FontSize="12"
                  FontWeight="SemiBold"
                  Opacity="0.7"
                  Margin="0,8,0,4"
                />
              </DataTemplate>
            </GroupStyle.HeaderTemplate>
          </GroupStyle>
        </ItemsControl.GroupStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border
              Margin="0,2"
              Padding="8,6"
              Background="{DynamicResource SurfaceBrush}"
              CornerRadius="4"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
            >
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="60" />
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <CheckBox
                  Grid.Column="0"
                  IsChecked="{Binding IsSelected}"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"
                />
                <TextBlock
                  Grid.Column="1"
                  Text="{Binding ProcessName}"
                  FontWeight="SemiBold"
                  FontSize="13"
                  VerticalAlignment="Center"
                  TextTrimming="CharacterEllipsis"
                />
                <TextBlock
                  Grid.Column="2"
                  Text="{Binding ProcessId}"
                  FontSize="12"
                  Opacity="0.6"
                  VerticalAlignment="Center"
                  FontFamily="{DynamicResource MonospaceFont}"
                />
                <TextBlock
                  Grid.Column="3"
                  Text="{Binding UserName}"
                  FontSize="12"
                  Opacity="0.7"
                  VerticalAlignment="Center"
                  TextTrimming="CharacterEllipsis"
                  Margin="8,0,0,0"
                />
                <TextBlock
                  Grid.Column="4"
                  Text="{Binding StartTimeDisplay}"
                  FontSize="12"
                  Opacity="0.6"
                  VerticalAlignment="Center"
                  TextTrimming="CharacterEllipsis"
                  Margin="8,0,0,0"
                />

                <TextBlock
                  Grid.Row="1"
                  Grid.Column="1"
                  Grid.ColumnSpan="4"
                  Text="{Binding ErrorMessage}"
                  FontSize="11"
                  Foreground="{DynamicResource ErrorBrush}"
                  TextWrapping="Wrap"
                  Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                  Margin="0,2,0,0"
                />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Grid Margin="0,4,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock
        FontSize="12"
        FontWeight="SemiBold"
        Opacity="0.5"
        Margin="4,0,24,0"
        VerticalAlignment="Center"
      >
        <TextBlock.Inlines>
          <Run Text="{DynamicResource LockedFiles_ProcessName}" />
          <Run Text=" | " />
          <Run Text="{DynamicResource LockedFiles_PID}" />
          <Run Text=" | " />
          <Run Text="{DynamicResource LockedFiles_User}" />
          <Run Text=" | " />
          <Run Text="{DynamicResource LockedFiles_Running}" />
        </TextBlock.Inlines>
      </TextBlock>
    </Grid>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button
        x:Name="SkipButton"
        Content="{DynamicResource LockedFiles_Skip}"
        Style="{DynamicResource OutlinedButton}"
        Padding="16,8"
        Margin="0,0,8,0"
        ToolTip="{DynamicResource LockedFiles_SkipHint}"
        Click="Skip_Click"
      />
      <Button
        x:Name="RefreshButton"
        Content="{DynamicResource LockedFiles_Refresh}"
        Style="{DynamicResource OutlinedButton}"
        Padding="16,8"
        Margin="0,0,8,0"
        Click="Refresh_Click"
      />
      <Button
        x:Name="KillButton"
        Content="{DynamicResource LockedFiles_Kill}"
        Style="{DynamicResource FilledAccentButton}"
        Padding="16,8"
        Click="KillSelected_Click"
        IsEnabled="False"
      />
    </StackPanel>
  </StackPanel>
</Window>
