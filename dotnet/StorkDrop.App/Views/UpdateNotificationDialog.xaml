<Window
  x:Class="StorkDrop.App.Views.UpdateNotificationDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="{DynamicResource Update_Available_Title}"
  Icon="/Assets/stork.ico"
  Width="450"
  Height="350"
  WindowStartupLocation="CenterOwner"
  ResizeMode="NoResize"
  Background="White"
>
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock x:Name="HeaderText" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

    <TextBlock
      Grid.Row="1"
      Text="{DynamicResource Update_ReleaseNotes}"
      FontSize="13"
      FontWeight="SemiBold"
      Foreground="#666666"
      Margin="0,8,0,6"
    />

    <Border Grid.Row="2" Background="#F8F8F8" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TextBlock
          x:Name="ReleaseNotesText"
          FontSize="13"
          TextWrapping="Wrap"
          Foreground="#444444"
        />
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button
        Content="{DynamicResource Update_Later}"
        Padding="16,8"
        Margin="0,0,8,0"
        Click="OnLaterClick"
      />
      <Button
        Content="{DynamicResource Update_Now}"
        Padding="16,8"
        FontWeight="SemiBold"
        Background="#C8102E"
        Foreground="White"
        BorderThickness="0"
        Click="OnUpdateNowClick"
      />
    </StackPanel>
  </Grid>
</Window>
