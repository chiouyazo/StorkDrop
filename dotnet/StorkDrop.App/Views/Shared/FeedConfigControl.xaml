<UserControl
  x:Class="StorkDrop.App.Views.Shared.FeedConfigControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <StackPanel>
    <TextBlock
      Text="{DynamicResource Settings_FeedName}"
      Style="{DynamicResource BodyText}"
      Margin="0,0,0,4"
    />
    <TextBox
      Text="{Binding FeedName, UpdateSourceTrigger=PropertyChanged}"
      Padding="8,6"
      FontSize="13"
      Margin="0,0,0,12"
    />

    <TextBlock
      Text="{DynamicResource Settings_FeedUrl}"
      Style="{DynamicResource BodyText}"
      Margin="0,0,0,4"
    />
    <TextBox
      Text="{Binding FeedUrl, UpdateSourceTrigger=PropertyChanged}"
      Padding="8,6"
      FontSize="13"
      Margin="0,0,0,12"
    />

    <TextBlock
      Text="{DynamicResource Settings_FeedRepo}"
      Style="{DynamicResource BodyText}"
      Margin="0,0,0,4"
    />
    <TextBox
      Text="{Binding FeedRepository, UpdateSourceTrigger=PropertyChanged}"
      Padding="8,6"
      FontSize="13"
      Margin="0,0,0,12"
    />

    <TextBlock
      Text="{DynamicResource Settings_FeedUser}"
      Style="{DynamicResource BodyText}"
      Margin="0,0,0,4"
    />
    <TextBox
      Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
      Padding="8,6"
      FontSize="13"
      Margin="0,0,0,12"
    />

    <TextBlock
      Text="{DynamicResource Settings_FeedPass}"
      Style="{DynamicResource BodyText}"
      Margin="0,0,0,4"
    />
    <PasswordBox x:Name="PasswordBox" Padding="8,6" FontSize="13" Margin="0,0,0,20" />

    <StackPanel Orientation="Horizontal">
      <Button
        Content="{DynamicResource Button_TestConnection}"
        Style="{DynamicResource OutlinedButton}"
        Command="{Binding TestConnectionCommand}"
        Padding="16,6"
        Margin="0,0,12,0"
      />
      <TextBlock Text="{Binding ConnectionTestMessage}" VerticalAlignment="Center" FontSize="13">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsConnectionValid}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding IsConnectionValid}" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </StackPanel>
  </StackPanel>
</UserControl>
