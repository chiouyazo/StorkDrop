<UserControl
  x:Class="StorkDrop.App.Views.Installed.InstalledView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
  Loaded="OnLoaded"
>
  <UserControl.Resources>
    <CollectionViewSource x:Key="GroupedProducts" Source="{Binding Products}">
      <CollectionViewSource.SortDescriptions>
        <scm:SortDescription PropertyName="IsExecutable" Direction="Descending" />
        <scm:SortDescription PropertyName="Title" Direction="Ascending" />
      </CollectionViewSource.SortDescriptions>
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="IsExecutable" />
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
  </UserControl.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Margin="0,0,0,16">
      <TextBlock
        Text="{DynamicResource Installed_Title}"
        Style="{DynamicResource HeadingLarge}"
        VerticalAlignment="Center"
      />
      <Button
        Content="&#xE72C;"
        FontFamily="Segoe MDL2 Assets"
        FontSize="16"
        Background="Transparent"
        BorderThickness="0"
        Foreground="#666666"
        Cursor="Hand"
        HorizontalAlignment="Right"
        ToolTip="{DynamicResource Refresh}"
        Padding="8"
        Command="{Binding LoadCommand}"
      />
    </Grid>

    <!-- Notification area -->
    <Border
      x:Name="NotificationBanner"
      Grid.Row="1"
      Background="#FFF3E0"
      CornerRadius="6"
      Padding="12,8"
      Margin="0,0,0,12"
      Visibility="Collapsed"
    >
      <TextBlock x:Name="NotificationText" FontSize="13" Foreground="#E65100" TextWrapping="Wrap" />
    </Border>

    <ListView
      Grid.Row="2"
      ItemsSource="{Binding Source={StaticResource GroupedProducts}}"
      BorderThickness="0"
      Background="Transparent"
      Visibility="{Binding HasProducts, Converter={StaticResource BoolToVisibilityConverter}}"
    >
      <ListView.GroupStyle>
        <GroupStyle>
          <GroupStyle.HeaderTemplate>
            <DataTemplate>
              <TextBlock
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="{DynamicResource OnSurfaceVariantBrush}"
                Margin="0,12,0,8"
              >
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="{DynamicResource Installed_GroupProducts}" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Name}" Value="True">
                        <Setter Property="Text" Value="{DynamicResource Installed_GroupActions}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </DataTemplate>
          </GroupStyle.HeaderTemplate>
        </GroupStyle>
      </ListView.GroupStyle>
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="Margin" Value="0" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListViewItem">
                <ContentPresenter />
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate>
          <Border Style="{DynamicResource CardBorder}" Margin="0,0,0,8" MinWidth="600">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock
                  Text="{Binding Title}"
                  Style="{DynamicResource HeadingSmall}"
                  Margin="0,0,0,4"
                />
                <StackPanel Orientation="Horizontal">
                  <TextBlock
                    Text="{DynamicResource Installed_Version}"
                    FontSize="12"
                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                    Margin="0,0,4,0"
                  />
                  <TextBlock
                    Text="{Binding Version}"
                    FontSize="12"
                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                  />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock
                    Text="{DynamicResource Installed_Path}"
                    FontSize="12"
                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                    Margin="0,0,4,0"
                  />
                  <TextBlock
                    Text="{Binding InstalledPath}"
                    FontSize="12"
                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                  />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock
                    Text="{DynamicResource Installed_Date}"
                    FontSize="12"
                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                    Margin="0,0,4,0"
                  />
                  <TextBlock
                    Text="{Binding InstalledDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                    FontSize="12"
                    Foreground="{DynamicResource OnSurfaceVariantBrush}"
                  />
                </StackPanel>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button
                  Style="{DynamicResource FilledAccentButton}"
                  Command="{Binding DataContext.ReExecutePluginsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  CommandParameter="{Binding}"
                  Padding="12,6"
                  Margin="0,0,8,0"
                  Visibility="{Binding IsExecutable, Converter={StaticResource BoolToVisibilityConverter}}"
                >
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" />
                    <TextBlock Text="{DynamicResource ReExecute_Run}" />
                  </StackPanel>
                </Button>
                <Button
                  Content="&#xE945;"
                  FontFamily="Segoe MDL2 Assets"
                  Command="{Binding DataContext.ReExecutePluginsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  CommandParameter="{Binding}"
                  ToolTip="{DynamicResource ReExecute_Button}"
                  Padding="10,6"
                  Margin="0,0,8,0"
                >
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource OutlinedButton}">
                      <Setter
                        Property="Visibility"
                        Value="{Binding HasActions, Converter={StaticResource BoolToVisibilityConverter}}"
                      />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExecutable}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <Button
                  Style="{DynamicResource OutlinedButton}"
                  Command="{Binding DataContext.UninstallCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  CommandParameter="{Binding}"
                  Padding="12,6"
                >
                  <Button.Content>
                    <TextBlock>
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="{DynamicResource Installed_Uninstall}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExecutable}" Value="True">
                              <Setter Property="Text" Value="{DynamicResource Installed_Remove}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Button.Content>
                </Button>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <!-- Empty State -->
    <StackPanel
      Grid.Row="2"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Visibility="{Binding HasNoProducts, Converter={StaticResource BoolToVisibilityConverter}}"
    >
      <TextBlock
        Text="&#xE74C;"
        FontFamily="Segoe MDL2 Assets"
        FontSize="48"
        Foreground="{DynamicResource OnSurfaceVariantBrush}"
        HorizontalAlignment="Center"
        Opacity="0.3"
        Margin="0,0,0,12"
      />
      <TextBlock
        Text="{DynamicResource Installed_NoProducts}"
        Style="{DynamicResource BodyText}"
        Foreground="{DynamicResource OnSurfaceVariantBrush}"
        HorizontalAlignment="Center"
      />
    </StackPanel>
  </Grid>
</UserControl>
