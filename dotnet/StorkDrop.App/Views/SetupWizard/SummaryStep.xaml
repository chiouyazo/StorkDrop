<UserControl
    x:Class="StorkDrop.App.Views.SetupWizard.SummaryStep"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock
                Text="{DynamicResource Setup_Summary_Title}"
                Style="{DynamicResource HeadingMedium}"
                Margin="0,0,0,8"
            />
            <TextBlock
                Text="{DynamicResource Setup_Summary_Subtitle}"
                Style="{DynamicResource CaptionText}"
                Margin="0,0,0,24"
            />

            <!-- Feed Connection -->
            <Border Style="{DynamicResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock
                        Text="{DynamicResource Setup_Connection_Title}"
                        Style="{DynamicResource HeadingSmall}"
                        Margin="0,0,0,8"
                    />
                    <TextBlock Style="{DynamicResource BodyText}">
                        <Run Text="Name: " FontWeight="SemiBold" />
                        <Run Text="{Binding FeedName, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Style="{DynamicResource BodyText}">
                        <Run Text="URL: " FontWeight="SemiBold" />
                        <Run Text="{Binding FeedUrl, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Style="{DynamicResource BodyText}">
                        <Run Text="Repository: " FontWeight="SemiBold" />
                        <Run Text="{Binding FeedRepository, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Style="{DynamicResource BodyText}">
                        <Run Text="Username: " FontWeight="SemiBold" />
                        <Run Text="{Binding Username, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Options -->
            <Border Style="{DynamicResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock
                        Text="Options"
                        Style="{DynamicResource HeadingSmall}"
                        Margin="0,0,0,8"
                    />

                    <CheckBox
                        Content="{DynamicResource Settings_AutoStart}"
                        IsChecked="{Binding AutoStart}"
                        Margin="0,0,0,8"
                    />

                    <CheckBox
                        Content="{DynamicResource Settings_AutoUpdate}"
                        IsChecked="{Binding AutoCheckForUpdates}"
                        Margin="0,0,0,8"
                    />
                </StackPanel>
            </Border>

            <!-- Advanced -->
            <Expander
                Header="{DynamicResource Settings_Advanced}"
                Margin="0,0,0,16"
            >
                <Border Style="{DynamicResource CardBorder}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock
                            Text="{DynamicResource Settings_Proxy}"
                            Style="{DynamicResource HeadingSmall}"
                            Margin="0,0,0,8"
                        />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,8,0">
                                <TextBlock
                                    Text="Host"
                                    Style="{DynamicResource CaptionText}"
                                    Margin="0,0,0,4"
                                />
                                <TextBox
                                    Text="{Binding ProxyHost, UpdateSourceTrigger=PropertyChanged}"
                                    Padding="8,6"
                                    FontSize="13"
                                />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    Text="Port"
                                    Style="{DynamicResource CaptionText}"
                                    Margin="0,0,0,4"
                                />
                                <TextBox
                                    Text="{Binding ProxyPort, UpdateSourceTrigger=PropertyChanged}"
                                    Padding="8,6"
                                    FontSize="13"
                                />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- Hint -->
            <TextBlock
                Text="{DynamicResource Settings_Hint}"
                Style="{DynamicResource CaptionText}"
                Foreground="{DynamicResource OnSurfaceVariantBrush}"
                FontStyle="Italic"
                Margin="0,0,0,16"
            />
        </StackPanel>
    </ScrollViewer>
</UserControl>
