<Window
  x:Class="StorkDrop.App.Views.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="clr-namespace:StorkDrop.App.ViewModels"
  xmlns:marketplace="clr-namespace:StorkDrop.App.Views.Marketplace"
  xmlns:installed="clr-namespace:StorkDrop.App.Views.Installed"
  xmlns:updates="clr-namespace:StorkDrop.App.Views.Updates"
  xmlns:settings="clr-namespace:StorkDrop.App.Views.Settings"
  xmlns:activitylog="clr-namespace:StorkDrop.App.Views.ActivityLog"
  xmlns:plugins="clr-namespace:StorkDrop.App.Views.Plugins"
  xmlns:plugintab="clr-namespace:StorkDrop.App.Views.PluginTab"
  Title="StorkDrop"
  Icon="/Assets/stork.ico"
  Width="1200"
  Height="800"
  MinWidth="900"
  MinHeight="600"
  WindowStartupLocation="CenterScreen"
  Background="White"
>
  <Window.Resources>
    <DataTemplate DataType="{x:Type vm:MarketplaceViewModel}">
      <marketplace:MarketplaceView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:InstalledViewModel}">
      <installed:InstalledView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:UpdatesViewModel}">
      <updates:UpdatesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
      <settings:SettingsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ActivityLogViewModel}">
      <activitylog:ActivityLogView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PluginsViewModel}">
      <plugins:PluginsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ProductDetailViewModel}">
      <marketplace:ProductDetailView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PluginTabViewModel}">
      <plugintab:PluginTabView />
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Navigation Rail -->
    <Border
      Grid.Column="0"
      Grid.Row="0"
      Background="#F5F5F5"
      BorderBrush="#E0E0E0"
      BorderThickness="0,0,1,0"
    >
      <DockPanel>
        <!-- Logo -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,16,16,20">
          <Image Source="/Assets/stork_icon_64.png" Height="28" VerticalAlignment="Center" />
          <TextBlock
            Text="StorkDrop"
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="#444444"
            Margin="8,0,0,0"
            VerticalAlignment="Center"
          />
        </StackPanel>

        <!-- Navigation buttons -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <Button
              Command="{Binding NavigateToCommand}"
              CommandParameter="Marketplace"
              Background="Transparent"
              BorderThickness="0"
              HorizontalContentAlignment="Left"
              Cursor="Hand"
              Padding="16,10"
              Margin="6,1"
            >
              <StackPanel Orientation="Horizontal">
                <TextBlock
                  Text="&#xE8A9;"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="16"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="{DynamicResource Nav_Marketplace}"
                  FontSize="13"
                  Margin="10,0,0,0"
                  VerticalAlignment="Center"
                />
              </StackPanel>
            </Button>

            <Button
              Command="{Binding NavigateToCommand}"
              CommandParameter="Installed"
              Background="Transparent"
              BorderThickness="0"
              HorizontalContentAlignment="Left"
              Cursor="Hand"
              Padding="16,10"
              Margin="6,1"
            >
              <StackPanel Orientation="Horizontal">
                <TextBlock
                  Text="&#xE74C;"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="16"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="{DynamicResource Nav_Installed}"
                  FontSize="13"
                  Margin="10,0,0,0"
                  VerticalAlignment="Center"
                />
              </StackPanel>
            </Button>

            <Button
              Command="{Binding NavigateToCommand}"
              CommandParameter="Updates"
              Background="Transparent"
              BorderThickness="0"
              HorizontalContentAlignment="Left"
              Cursor="Hand"
              Padding="16,10"
              Margin="6,1"
            >
              <StackPanel Orientation="Horizontal">
                <TextBlock
                  Text="&#xE896;"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="16"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="{DynamicResource Nav_Updates}"
                  FontSize="13"
                  Margin="10,0,0,0"
                  VerticalAlignment="Center"
                />
              </StackPanel>
            </Button>

            <Button
              Command="{Binding NavigateToCommand}"
              CommandParameter="ActivityLog"
              Background="Transparent"
              BorderThickness="0"
              HorizontalContentAlignment="Left"
              Cursor="Hand"
              Padding="16,10"
              Margin="6,1"
            >
              <StackPanel Orientation="Horizontal">
                <TextBlock
                  Text="&#xE81C;"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="16"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="{DynamicResource Nav_ActivityLog}"
                  FontSize="13"
                  Margin="10,0,0,0"
                  VerticalAlignment="Center"
                />
              </StackPanel>
            </Button>

            <Button
              Command="{Binding NavigateToCommand}"
              CommandParameter="Plugins"
              Background="Transparent"
              BorderThickness="0"
              HorizontalContentAlignment="Left"
              Cursor="Hand"
              Padding="16,10"
              Margin="6,1"
            >
              <StackPanel Orientation="Horizontal">
                <TextBlock
                  Text="&#xE74C;"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="16"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="{DynamicResource Nav_Plugins}"
                  FontSize="13"
                  Margin="10,0,0,0"
                  VerticalAlignment="Center"
                />
              </StackPanel>
            </Button>

            <!-- Plugin-contributed navigation tabs -->
            <ItemsControl ItemsSource="{Binding PluginNavTabs}">
              <ItemsControl.Style>
                <Style TargetType="ItemsControl">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding PluginNavTabs.Count}" Value="0">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </ItemsControl.Style>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button
                    Command="{Binding DataContext.NavigateToPluginTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Left"
                    Cursor="Hand"
                    Padding="16,10"
                    Margin="6,1"
                  >
                    <StackPanel Orientation="Horizontal">
                      <TextBlock
                        Text="{Binding Icon}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="16"
                        VerticalAlignment="Center"
                      />
                      <TextBlock
                        Text="{Binding DisplayName}"
                        FontSize="13"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                      />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Settings (always last) -->
            <Button
              Command="{Binding NavigateToCommand}"
              CommandParameter="Settings"
              Background="Transparent"
              BorderThickness="0"
              HorizontalContentAlignment="Left"
              Cursor="Hand"
              Padding="16,10"
              Margin="6,1"
            >
              <StackPanel Orientation="Horizontal">
                <TextBlock
                  Text="&#xE713;"
                  FontFamily="Segoe MDL2 Assets"
                  FontSize="16"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="{DynamicResource Nav_Settings}"
                  FontSize="13"
                  Margin="10,0,0,0"
                  VerticalAlignment="Center"
                />
              </StackPanel>
            </Button>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- Content Area -->
    <ContentControl
      x:Name="ContentRegion"
      Grid.Column="1"
      Grid.Row="0"
      Content="{Binding CurrentContent}"
      Margin="24,16"
    />

    <!-- Status Bar -->
    <Border
      Grid.Row="1"
      Grid.ColumnSpan="2"
      Background="#F5F5F5"
      BorderBrush="#E0E0E0"
      BorderThickness="0,1,0,0"
      Padding="16,6"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Connection status -->
        <Button
          Grid.Column="0"
          Command="{Binding NavigateToCommand}"
          CommandParameter="Settings"
          Background="Transparent"
          BorderThickness="0"
          Cursor="Hand"
          Padding="0"
        >
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="8" Height="8" Margin="0,0,8,0">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#D32F2F" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                      <Setter Property="Fill" Value="#2E7D32" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#666666" />
          </StackPanel>
        </Button>

        <!-- Plugin status -->
        <Button
          Grid.Column="1"
          Command="{Binding NavigateToPluginsCommand}"
          Background="Transparent"
          BorderThickness="0"
          Cursor="Hand"
          Padding="0"
          Margin="16,0,0,0"
        >
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding PluginStatusText}" Value="">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="8" Height="8" Margin="0,0,8,0" Fill="{Binding PluginStatusColor}" />
            <TextBlock Text="{Binding PluginStatusText}" FontSize="11" Foreground="#666666" />
          </StackPanel>
        </Button>

        <!-- Installation status indicator -->
        <Button
          Grid.Column="2"
          Margin="16,0,0,0"
          Background="Transparent"
          BorderThickness="0"
          Cursor="Hand"
          HorizontalAlignment="Right"
          Padding="8,4"
          Command="{Binding ToggleInstallationPanelCommand}"
        >
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger
                  Binding="{Binding InstallationTracker.HasActiveInstallations}"
                  Value="True"
                >
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ShowInstallationPanel}" Value="True">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <StackPanel Orientation="Horizontal">
            <TextBlock
              Text="&#xE896;"
              FontFamily="Segoe MDL2 Assets"
              FontSize="14"
              Foreground="#1565C0"
              VerticalAlignment="Center"
              Margin="0,0,6,0"
            />
            <TextBlock FontSize="11" Foreground="#1565C0" VerticalAlignment="Center">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} installation(s)">
                  <Binding Path="InstallationTracker.Installations.Count" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
        </Button>

        <TextBlock
          Grid.Column="3"
          HorizontalAlignment="Right"
          FontSize="11"
          Foreground="#666666"
          Cursor="Hand"
          MouseLeftButtonDown="OnVersionClick"
        >
          <Run x:Name="VersionRun" Text="StorkDrop" />
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="TextDecorations" Value="Underline" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>
    </Border>

    <!-- Installation panel (overlay, anchored to bottom-right) -->
    <Border
      Grid.Row="0"
      Grid.ColumnSpan="2"
      HorizontalAlignment="Right"
      VerticalAlignment="Bottom"
      Margin="0,0,16,8"
      Width="420"
      MaxHeight="350"
      Background="White"
      BorderBrush="#E0E0E0"
      BorderThickness="1"
      CornerRadius="8"
      Visibility="{Binding ShowInstallationPanel, Converter={StaticResource BoolToVisibilityConverter}}"
    >
      <Border.Effect>
        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" />
      </Border.Effect>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Panel header -->
        <Border Background="#F5F5F5" CornerRadius="8,8,0,0" Padding="12,8">
          <Grid>
            <TextBlock
              Text="Installations"
              FontSize="13"
              FontWeight="SemiBold"
              VerticalAlignment="Center"
            />
            <Button
              Content="&#xE711;"
              FontFamily="Segoe MDL2 Assets"
              FontSize="12"
              Background="Transparent"
              BorderThickness="0"
              Cursor="Hand"
              HorizontalAlignment="Right"
              Padding="4"
              Command="{Binding ToggleInstallationPanelCommand}"
            />
          </Grid>
        </Border>

        <!-- Installation list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
          <ItemsControl ItemsSource="{Binding InstallationTracker.Installations}" Margin="8">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border
                  BorderBrush="#F0F0F0"
                  BorderThickness="0,0,0,1"
                  Padding="4,8"
                  Cursor="Hand"
                  MouseLeftButtonDown="OnInstallationItemClick"
                >
                  <StackPanel>
                    <Grid>
                      <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" />
                      <!-- Status icon -->
                      <TextBlock HorizontalAlignment="Right" FontSize="11">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="..." />
                            <Setter Property="Foreground" Value="#999999" />
                            <Style.Triggers>
                              <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                  <Condition Binding="{Binding IsCompleted}" Value="True" />
                                  <Condition Binding="{Binding IsSuccess}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Text" Value="&#xE73E;" />
                                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                                <Setter Property="Foreground" Value="#2E7D32" />
                              </MultiDataTrigger>
                              <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                  <Condition Binding="{Binding IsCompleted}" Value="True" />
                                  <Condition Binding="{Binding IsSuccess}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Text" Value="&#xE711;" />
                                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                                <Setter Property="Foreground" Value="#D32F2F" />
                              </MultiDataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Grid>
                    <TextBlock
                      Text="{Binding StatusMessage}"
                      FontSize="11"
                      Foreground="#999999"
                      Margin="0,2,0,0"
                      TextTrimming="CharacterEllipsis"
                    />
                    <!-- Progress bar (only when active) -->
                    <ProgressBar
                      Value="{Binding Percentage}"
                      Maximum="100"
                      Height="3"
                      Margin="0,4,0,0"
                    >
                      <ProgressBar.Style>
                        <Style
                          TargetType="ProgressBar"
                          BasedOn="{StaticResource StyledProgressBar}"
                        >
                          <Setter Property="IsIndeterminate" Value="False" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Percentage}" Value="0">
                              <Setter Property="IsIndeterminate" Value="True" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ProgressBar.Style>
                    </ProgressBar>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</Window>
