<Window
  x:Class="StorkDrop.App.Views.RequiredComponentsDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="{DynamicResource RequiredComponents_Title}"
  Width="450"
  SizeToContent="Height"
  WindowStartupLocation="CenterOwner"
  ResizeMode="NoResize"
  Background="{DynamicResource BackgroundBrush}"
>
  <StackPanel Margin="24">
    <TextBlock
      Text="{DynamicResource RequiredComponents_Title}"
      FontSize="18"
      FontWeight="SemiBold"
      Margin="0,0,0,12"
    />
    <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,12" />
    <ItemsControl x:Name="MissingList" Margin="0,0,0,16">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding}" FontSize="13" Margin="8,2" Foreground="#D32F2F" />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button
        Content="{DynamicResource RequiredComponents_Cancel}"
        Style="{DynamicResource OutlinedButton}"
        Padding="16,8"
        Margin="0,0,8,0"
        Click="Cancel_Click"
      />
      <Button
        Content="{DynamicResource RequiredComponents_Proceed}"
        Style="{DynamicResource FilledAccentButton}"
        Padding="16,8"
        Click="Proceed_Click"
      />
    </StackPanel>
  </StackPanel>
</Window>
